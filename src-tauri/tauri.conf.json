{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Theme Package Editor",
  "version": "1.0.0",
  "identifier": "com.qtrade.theme-package-editor",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Theme Package Editor",
        "width": 1440,
        "height": 960,
        "minWidth": 1160,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "GraphicsAndDesign",
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
